# ─── Strapi CMS ────────────────────────────────────────────────────────────────
# URL base de la instancia de Strapi (sin trailing slash).
# En producción, reemplazar por la URL pública del servidor Strapi.
API_URL=http://localhost:1337

# ─── Dynamic Zone ──────────────────────────────────────────────────────────────
# Prefijo de zona que Strapi antepone a cada componente en el campo __component.
# Ejemplo: si Strapi devuelve "blocks.hero", el valor debe ser "blocks".
# DynamicZone.astro lo usa para extraer el slug del componente (ej: "hero")
# y resolver el componente correcto desde content-type.ts.
DYNAMIC_ZONE=blocks

# ─── Página de inicio ──────────────────────────────────────────────────────────
# documentId de la entrada de Strapi que se usa como contenido del home (index.astro).
# Se obtiene desde el panel de Strapi → Content Manager → (tu colección home) → documentId.
DOCUMENT_ID=ljql434vw8kzx9zop5gfqnqf