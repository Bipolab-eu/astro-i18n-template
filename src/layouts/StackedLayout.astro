---
import { Separator } from "@/components/starwind/separator";
import { Button } from "@/components/starwind/button";
import LanguagePicker from "@/components/LanguagePicker.astro";
import { Menu } from "@lucide/astro";
import {
  Dialog,
  DialogTrigger,
  DialogContent,
  DialogClose,
} from "@/components/starwind/dialog";

const currentPath = Astro.url.pathname;

const navItems = [
  { title: "Dashboard", path: "#page-1" },
  { title: "Team", path: "#page-2" },
  { title: "Projects", path: "#page-3" },
  { title: "Calendar", path: "#page-4" },
];
---

<div class="relative isolate flex min-h-svh w-full flex-col bg-neutral-50 lg:bg-neutral-100">
  <!-- Mobile Sidebar -->
  <Dialog class='p-2 lg:hidden'>
    <DialogTrigger asChild>
      <Button variant="ghost"><Menu /></Button>
    </DialogTrigger>
    <DialogContent animationDuration={300} class='top-0 left-0 translate-x-0 w-2/3 min-h-svh'>
        {
          navItems.map((item) => (
            <DialogClose asChild>
              <Button href={item.path} variant="ghost" size="sm" class='block w-full text-left'>
                {item.title}
              </Button>
            </DialogClose>
          ))
        }
    </DialogContent>
  </Dialog>

  <header class="hidden lg:inline-flex p-2">
    <!-- Brand logo -->
    <div class="inline-flex items-center">
      <Button href="/" size="sm" variant="ghost">Logotipo</Button>
      <Separator orientation="vertical" class="bg-neutral-400 h-full" />
    </div>

    <!-- Desktop: Navigation + Language Picker -->
    <div class="lg:flex lg:flex-1 lg:items-center lg:justify-between">
      <nav class="lg:flex items-center">
        {
          navItems.map((item) => (
            <Button href={item.path} variant="ghost" size="sm">
              {item.title}
            </Button>
          ))
        }
      </nav>
      <LanguagePicker />
    </div>
  </header>

  
  <!-- Main content -->
  <main class="flex flex-1 flex-col pb-2 lg:px-2">
    <div
      class="grow p-6 lg:rounded-lg lg:bg-neutral-50 lg:p-10 lg:shadow-xs lg:ring-1 lg:ring-neutral-950/5"
    >
      <div class="mx-auto max-w-7xl">
        <slot />
      </div>
    </div>
  </main>
</div>
