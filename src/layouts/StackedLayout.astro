---
import {
  Dropdown,
  DropdownTrigger,
  DropdownContent,
  DropdownItem,
  DropdownSeparator,
} from "@/components/starwind/dropdown";
import { Button } from "@/components/starwind/button";
import Navbar from "@/components/Navbar.astro";
import { Menu } from "@lucide/astro";
---

<div class="relative isolate flex min-h-svh w-full flex-col bg-neutral-50 lg:bg-neutral-100">

  <header class="flex items-center px-4">

    <!-- Logo -->
    <a href="/" class="flex shrink-0 items-center py-4">
      <img
        src="https://tailwindcss.com/plus-assets/img/logos/mark.svg?color=indigo&shade=600"
        alt="Logo"
        class="h-8 w-auto"
      />
    </a>

    <!-- Mobile: menú hamburguesa -->
    <div class="py-2.5 lg:hidden ml-auto">
      <Dropdown>
        <DropdownTrigger asChild>
          <Button variant="ghost" size="icon-sm" aria-label="Abrir menú">
            <Menu />
          </Button>
        </DropdownTrigger>
        <DropdownContent align="end" class="w-56">
          <DropdownItem as="a" href="#">Dashboard</DropdownItem>
          <DropdownItem as="a" href="#">Team</DropdownItem>
          <DropdownItem as="a" href="#">Projects</DropdownItem>
          <DropdownSeparator />
          <DropdownItem as="a" href="#">Settings</DropdownItem>
        </DropdownContent>
      </Dropdown>
    </div>

    <!-- Desktop: navbar completa -->
    <div class="hidden lg:flex lg:flex-1">
      <Navbar />
    </div>

  </header>

  <!-- Main content -->
  <main class="flex flex-1 flex-col pb-2 lg:px-2">
    <div
      class="grow p-6 lg:rounded-lg lg:bg-neutral-50 lg:p-10 lg:shadow-xs lg:ring-1 lg:ring-neutral-950/5"
    >
      <div class="mx-auto max-w-6xl">
        <slot />
      </div>
    </div>
  </main>

</div>
