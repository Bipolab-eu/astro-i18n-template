---
/* Top Level Pages */

import DynamicZone from "../../../layouts/DynamicZone.astro";
import Layout from "../../../layouts/Layout.astro";
import { fetchApi } from "../../../lib/strapi/fetchApi";

const { lang, page } = Astro.params;
const DZ = import.meta.env.DYNAMIC_ZONE

// Busca la página por slug — devuelve array, se usa el primer resultado
const data = await fetchApi({
  apiRoute: "/api/pages",
  locale: lang,
  filters: {
    slug: {
      $eq: page,
    },
  },
}) as any

// data[0] porque la API devuelve array aunque el slug sea único
if (!data[0]) return Astro.redirect("/404")

const { seo, [DZ]: items, localizations } = data[0]

// Construye el mapa lang → URL traducida para el language switcher
// La página actual se incluye con su propio slug
const translatedUrls: Record<string, string> = {
  [lang!]: `/${lang}/${page}/`,
  ...Object.fromEntries(
    (localizations ?? []).map((loc: { slug: string; locale: string }) => [
      loc.locale,
      `/${loc.locale}/${loc.slug}/`,
    ])
  ),
}
---

<Layout seo={seo} translatedUrls={translatedUrls}>
  <DynamicZone blocks={items} />
</Layout>