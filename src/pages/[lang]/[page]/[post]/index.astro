---
/* Post entries */

import DynamicZone from "../../../../layouts/DynamicZone.astro";
import Layout from "../../../../layouts/Layout.astro";
import { fetchApi } from "../../../../lib/strapi/fetchApi";

const { post } = Astro.params;
const DZ = import.meta.env.DYNAMIC_ZONE

// Busca el post por slug — mismo patrón que [page] pero contra /api/posts
const data = await fetchApi({
  apiRoute: `/api/posts`,
  filters: {
    slug: {
      $eq: post,
    },
  },
}) as any

// data[0] porque la API devuelve array aunque el slug sea único
if (!data[0]) return Astro.redirect("/404")

const { seo, [DZ]:items } = data[0]
---

<Layout seo={seo}>
  <DynamicZone blocks={items} />
</Layout>